# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/smart_road_monitoring
PGSSL=false

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
COOKIE_SECRET=replace_with_a_long_random_cookie_secret

# Email (for forgot password / notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Smart Road Monitoring <no-reply@smartroad.app>"

# File uploads
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Rate limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=200

# AI detection service (optional external microservice)
AI_DETECTION_URL=http://localhost:8001/detect
AI_DETECTION_ENABLED=false
